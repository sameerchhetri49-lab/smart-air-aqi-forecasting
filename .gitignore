# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-log.txt

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
env/
.env/
.venv/
ENV/

# ── Jupyter ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Data files — raw and processed CSVs are excluded from version control ─────
# (raw data must be downloaded fresh; processed data is reproducible)
data/raw/*.csv
data/processed/*.csv

# ── Generated figures (reproducible from script) ──────────────────────────────
# Comment out these lines if you want to commit figures to the repo
data/figures/*.png
data/figures/*.pdf

# ── OS / IDE ───────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# ── Secrets / API keys ────────────────────────────────────────────────────────
.env
*.key
